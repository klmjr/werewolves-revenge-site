---
// src/layouts/Layout.astro
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Astro Basics</title>
	</head>
	<body>
		<nav class="main-nav">
			<a href="/">Home</a>
			<a href="/play">Play</a>
			<a href="/roles">Roles</a>
		</nav>

		<slot />
	</body>
</html>

<style is:global> /* Added 'is:global' so this font rules applies to all sub-pages too! */
	
	/* 1. DEFINE YOUR CUSTOM FONT */
	@font-face {
		font-family: 'MyCustomGameFont';
		src: url('/fonts/MyGameFont.ttf') format('truetype');
		font-weight: normal;
		font-style: normal;
		font-display: swap;
	}

	html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		
		/* 2. USE YOUR CUSTOM FONT */
		font-family: 'MyCustomGameFont', sans-serif;
		background: #181411;
		color: #ffffff;
	}

    html,
	body {
		margin: 0;
		width: 100%;
		height: 100%;
		font-family: sans-serif; /* Optional: Makes the text look clean */
	}

	/* Optional styling to make your navigation look clean and spaced out */
	.main-nav {
		padding: 1rem;
		display: flex;
		gap: 1.5rem;
	}

	.main-nav a {
		color: white;
		text-decoration: none;
		font-weight: bold;
	}

	.main-nav a:hover {
		color: #d1d1d1; /* Turns red on hover to match your game vibe */
	}
</style>