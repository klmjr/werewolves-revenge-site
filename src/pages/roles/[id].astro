---
// src/pages/roles/[id].astro
import Layout from '../../layouts/Layout.astro';
import rolesData from '../../data/roles.json';
import { getFactionTheme } from '../../data/factions';
import { getClassTheme } from '../../data/classes';

export async function getStaticPaths() {
  return rolesData.map((role) => {
    return {
      params: { id: role.id },
      props: { role },
    };
  });
}

const { role } = Astro.props;
const theme = getFactionTheme(role.faction);
const factionStyle = `--faction: ${theme.hex};`;
const classTheme = getClassTheme(role.class);
const classStyle = `--class: ${classTheme.hex};`;
---

<Layout title={`${role.name} | ${role.set}`}>
  <main class="bg-zinc-950 min-h-screen text-zinc-100 relative overflow-hidden pb-24" style={factionStyle}>

    <div class="absolute inset-0 faction-page-glow z-0 opacity-60"></div>

    <div class="max-w-6xl mx-auto px-6 pt-12 md:pt-24 relative z-10">
      <nav class="mb-12">
        <a href="/roles" class="text-zinc-500 hover:text-white uppercase tracking-widest text-sm font-bold transition-colors flex items-center gap-2">
          <span>&larr;</span> Back to All Roles
        </a>
      </nav>

      <div class="grid md:grid-cols-[1fr_1fr] gap-6 lg:gap-12 items-start">

        <div class="relative group">
          <div class="absolute -inset-1 faction-image-glow rounded-lg blur opacity-25 group-hover:opacity-50 transition duration-1000"></div>
          <div class="relative aspect-[2/3] bg-zinc-900 rounded-lg border border-zinc-800 overflow-hidden shadow-2xl">
            <img src={role.imageUrl || '/images/roles/default_portrait.webp'} alt={role.name} class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-zinc-950/20 to-transparent"></div>

            <div class="absolute inset-0 flex flex-col justify-end p-8 bg-zinc-950/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">Description</h3>
              <p class="text-lg text-zinc-300 leading-relaxed" set:html={role.descriptionHtml || role.description} />
            </div>
          </div>
        </div>

        <div class="py-6">
          <h1 class="text-4xl md:text-7xl font-black uppercase tracking-tighter mb-5 drop-shadow-lg" style="font-family: 'Beaufort', serif;">{role.name}</h1>

          <div class="flex flex-wrap gap-3 mb-6">
            <span class="faction-border flex items-center gap-2 px-4 py-1.5 rounded-lg border bg-zinc-950/50 backdrop-blur-sm text-s font-bold uppercase tracking-widest shadow-[0_0_12px_-2px_var(--faction)]">
              <span class="faction-text">{role.factionName}</span>
            </span>
            <span class="class-border flex items-center gap-2 px-4 py-1.5 rounded-lg border bg-zinc-950/50 backdrop-blur-sm text-s font-bold uppercase tracking-widest shadow-[0_0_12px_-2px_var(--class)]" style={classStyle}>
              <span class="class-text">{role.class}</span>
            </span>
            <!-- <span class="px-4 py-1 rounded border border-zinc-700 bg-zinc-800/50 backdrop-blur-sm text-xs font-bold uppercase tracking-widest text-zinc-400">
              {role.set}
            </span> -->
          </div>

          {role.group && (
            <div class="mb-6">
              <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">Group</h3>
              <div class="flex gap-4 bg-zinc-900/50 border border-zinc-800 rounded-xl p-5 backdrop-blur-sm" style={`--accent: ${role.group.color || '#71717a'};`}>
                {role.group.iconUrl && (
                  <img src={role.group.iconUrl} alt={role.group.name} class="w-16 h-16 object-contain shrink-0 rounded-xl" />
                )}
                <div class="flex-1">
                  <h4 class="accent-text text-lg font-bold mb-1">{role.group.name}</h4>
                  {role.group.description && (
                    <p class="text-lg text-zinc-300 leading-relaxed">{role.group.description}</p>
                  )}
                </div>
              </div>
            </div>
          )}

          {role.resource && (
            <div class="mb-6">
              <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">Resource</h3>
              <div class="flex gap-4 bg-zinc-900/50 border border-zinc-800 rounded-xl p-5 backdrop-blur-sm" style={`--accent: ${role.resource.color || '#71717a'};`}>
                {role.resource.iconUrl && (
                  <img src={role.resource.iconUrl} alt={role.resource.name} class="w-16 h-16 object-contain shrink-0 rounded-xl" />
                )}
                <div class="flex-1">
                  <h4 class="accent-text text-lg font-bold mb-1">{role.resource.name}</h4>
                  {role.resource.description && (
                    <p class="text-lg text-zinc-300 leading-relaxed">{role.resource.description}</p>
                  )}
                </div>
              </div>
            </div>
          )}

          {role.abilities && role.abilities.length > 0 && (
            <div>
              <h3 class="text-sm font-bold text-zinc-500 uppercase tracking-widest mb-4 border-b border-zinc-800 pb-2">Abilities</h3>
              <div class="space-y-4">
                {role.abilities.map((ability) => (
                  <div class="flex gap-4 bg-zinc-900/50 border border-zinc-800 rounded-xl p-5 backdrop-blur-sm">
                    {ability.iconUrl && (
                      <img src={ability.iconUrl} alt={ability.name} class="w-16 h-16 object-contain shrink-0 rounded-xl" />
                    )}
                    <div class="flex-1">
                      <div class="flex flex-wrap items-baseline justify-between gap-2 mb-1">
                        <h4 class="text-lg font-bold text-white">{ability.name}</h4>
                        <div class="flex gap-2 text-xs font-bold uppercase tracking-widest text-zinc-500">
                          {ability.abilityType && <span>{ability.abilityType}</span>}
                          {ability.costValue != null && ability.costValue > 0 && (
                            <span>&middot; {ability.costValue} {ability.costType}</span>
                          )}
                        </div>
                      </div>
                      <p class="text-lg text-zinc-300 leading-relaxed" set:html={ability.descriptionHtml || ability.description} />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  </main>
</Layout>