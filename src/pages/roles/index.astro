---
// src/pages/roles/index.astro
import Layout from '../../layouts/Layout.astro';
import rolesData from '../../data/roles.json';

const uniqueSets = [...new Set(rolesData.map(role => role.set))].filter(set => set !== "All");
---

<Layout title="Role Directory | Werewolves Revenge">
  
  <header class="bg-zinc-950 pt-24 pb-12 px-6 border-b border-zinc-800 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-zinc-800/40 via-zinc-950 to-zinc-950 z-0"></div>
    
    <div class="max-w-7xl mx-auto relative z-10 text-center">
      <h1 class="text-5xl md:text-6xl font-black text-white uppercase tracking-tighter mb-4 drop-shadow-lg">
        The <span class="text-red-600">Roles</span>
      </h1>
      
      <div class="flex flex-col md:flex-row justify-center items-center gap-4 max-w-3xl mx-auto mt-8">
        <select 
          id="setFilter" 
          class="bg-zinc-900 border border-zinc-700 text-white px-4 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors cursor-pointer appearance-none uppercase font-bold text-sm tracking-wider"
        >
          {uniqueSets.map(set => (
            <option value={set} selected={set === "Standard"}>{set}</option>
          ))}
        </select>

        <input 
          type="text" 
          id="searchInput"
          placeholder="Search roles..." 
          class="w-full md:w-96 bg-zinc-900 border border-zinc-700 text-white px-6 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors placeholder-zinc-600"
        />
      </div>
    </div>
  </header>

  <main class="bg-zinc-950 min-h-screen py-16 px-4 md:px-8 relative z-20">
    <div class="max-w-[1400px] mx-auto">
      
      <div class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-8 lg:grid-cols-10 gap-3 md:gap-4" id="rolesGrid">
        
        {rolesData.map((role) => {
          // UPDATE: Changed .team to .faction, and updated the default alignments
          // You can add more factions here (e.g., 'Villain', 'Gods', etc.)
          let borderGlow = "hover:border-zinc-500 hover:shadow-zinc-500/50";
          if (role.faction === "Hero" || role.faction === "Town") borderGlow = "hover:border-emerald-500 hover:shadow-emerald-500/50";
          if (role.faction === "Wolves" || role.faction === "Villain") borderGlow = "hover:border-red-500 hover:shadow-red-500/50";
          if (role.faction === "Neutral") borderGlow = "hover:border-amber-500 hover:shadow-amber-500/50";

          return (
            <a 
              href={`/roles/${role.id}`} 
              class={`role-card group relative block aspect-[2/3] bg-zinc-900 rounded border border-zinc-800 overflow-hidden transition-all duration-300 hover:scale-110 hover:z-30 hover:shadow-[0_0_20px_rgba(0,0,0,0.8)] ${borderGlow}`}
              data-set={role.set}
            >
              <img 
                src={role.portraitUrl || '/images/roles/default_portrait.png'} 
                alt={role.name} 
                class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity duration-300"
                loading="lazy" 
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black via-black/20 to-transparent opacity-90"></div>
              <div class="absolute bottom-0 left-0 right-0 p-2 text-center translate-y-1 group-hover:translate-y-0 transition-transform duration-300">
                <span class="block text-white font-bold text-xs md:text-sm truncate drop-shadow-md">{role.name}</span>
                <span class={`block text-[10px] font-bold uppercase tracking-widest ${
                  (role.faction === 'Hero' || role.faction === 'Town') ? 'text-emerald-400' : 
                  (role.faction === 'Wolves' || role.faction === 'Villain') ? 'text-red-500' : 'text-amber-400'
                }`}>{role.faction}</span>
              </div>
            </a>
          );
        })}
        
      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const setFilter = document.getElementById('setFilter');
    const searchInput = document.getElementById('searchInput');
    const roleCards = document.querySelectorAll('.role-card');

    function filterRoles() {
      const selectedSet = setFilter.value;
      const searchTerm = searchInput.value.toLowerCase();

      roleCards.forEach(card => {
        const roleName = card.querySelector('.truncate').textContent.toLowerCase();
        // Since we removed 'All', we strictly match the set
        const matchesSet = card.getAttribute('data-set') === selectedSet;
        const matchesSearch = roleName.includes(searchTerm);

        if (matchesSet && matchesSearch) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    }

    // Initialize filter on load to ensure "Standard" is shown immediately
    filterRoles();

    setFilter.addEventListener('change', filterRoles);
    searchInput.addEventListener('input', filterRoles);
  });
</script>