---
// src/pages/roles/index.astro
import Layout from '../../layouts/Layout.astro';
import rolesData from '../../data/roles.json';
import { getFactionTheme } from '../../data/factions';

const uniqueSets = [...new Set(rolesData.map(role => role.set))].filter(set => set !== "All");
const uniqueFactions = [...new Set(rolesData.map(role => role.faction))].sort();
const uniqueClasses = [...new Set(rolesData.map(role => role.class))].filter(Boolean).sort();

// "faction" is the internal id used for filtering/coloring; "factionName" is
// the display name shown to users. Build a lookup so the filter UI can show
// the display name while still filtering/storing by the internal id.
const factionDisplayNames = Object.fromEntries(rolesData.map(role => [role.faction, role.factionName]));
---

<Layout title="Role Directory | Werewolves Revenge">

  <header class="bg-zinc-950 pt-28 pb-8 px-6 border-b border-zinc-800 relative overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-zinc-800/40 via-zinc-950 to-zinc-950 z-0"></div>

    <div class="max-w-[1400px] mx-auto relative z-10 flex flex-col md:flex-row items-stretch md:items-center justify-between gap-4">
      <input
        type="text"
        id="searchInput"
        placeholder="Search roles..."
        class="w-full md:w-96 bg-zinc-900 border border-zinc-700 text-white px-6 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors placeholder-zinc-600"
      />

      <div class="flex flex-wrap items-center gap-3">
        <select
          id="setFilter"
          class="bg-zinc-900 border border-zinc-700 text-white px-4 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors cursor-pointer appearance-none uppercase font-bold text-sm tracking-wider"
        >
          {uniqueSets.map(set => (
            <option value={set} selected={set === "Standard"}>{set}</option>
          ))}
        </select>

        <select
          id="factionFilter"
          class="bg-zinc-900 border border-zinc-700 text-white px-4 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors cursor-pointer appearance-none uppercase font-bold text-sm tracking-wider"
        >
          <option value="" selected>All Factions</option>
          {uniqueFactions.map(faction => (
            <option value={faction}>{factionDisplayNames[faction] ?? faction}</option>
          ))}
        </select>

        <select
          id="classFilter"
          class="bg-zinc-900 border border-zinc-700 text-white px-4 py-3 rounded-md focus:outline-none focus:border-red-500 transition-colors cursor-pointer appearance-none uppercase font-bold text-sm tracking-wider"
        >
          <option value="" selected>All Classes</option>
          {uniqueClasses.map(roleClass => (
            <option value={roleClass}>{roleClass}</option>
          ))}
        </select>
      </div>
    </div>
  </header>

  <main class="bg-zinc-950 min-h-screen py-16 px-4 md:px-8 relative z-20">
    <div class="max-w-[1400px] mx-auto">
      
      <p id="noResults" class="hidden text-center text-zinc-500 py-16 text-lg">
        No roles match your search.
      </p>

      <div class="grid grid-cols-3 sm:grid-cols-5 md:grid-cols-8 lg:grid-cols-10 gap-3 md:gap-4" id="rolesGrid">

        {rolesData.map((role) => {
          const theme = getFactionTheme(role.faction);

          return (
            <a
              href={`/roles/${role.id}`}
              class="role-card faction-card group relative block aspect-square bg-zinc-900 rounded border border-zinc-800 overflow-hidden transition-transform duration-300 hover:scale-150 hover:z-30"
              style={`--faction: ${theme.hex};`}
              data-set={role.set}
              data-name={role.name.toLowerCase()}
              data-faction={role.faction}
              data-class={role.class}
              aria-label={role.name}
            >
              <img
                src={role.portraitUrl || '/images/roles/default_portrait.webp'}
                alt={role.name}
                class="w-full h-full object-cover"
                loading="lazy"
              />
            </a>
          );
        })}
        
      </div>
    </div>
  </main>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const roleCards = document.querySelectorAll<HTMLAnchorElement>('.role-card');

    function filterRoles() {
      const setFilter = document.getElementById('setFilter');
      const factionFilter = document.getElementById('factionFilter');
      const classFilter = document.getElementById('classFilter');
      const searchInput = document.getElementById('searchInput');
      const noResults = document.getElementById('noResults');

      if (
        !(setFilter instanceof HTMLSelectElement) ||
        !(factionFilter instanceof HTMLSelectElement) ||
        !(classFilter instanceof HTMLSelectElement) ||
        !(searchInput instanceof HTMLInputElement) ||
        !noResults
      ) {
        return;
      }

      const selectedSet = setFilter.value;
      const selectedFaction = factionFilter.value;
      const selectedClass = classFilter.value;
      const searchTerm = searchInput.value.trim().toLowerCase();
      let visibleCount = 0;

      roleCards.forEach(card => {
        const roleName = card.dataset.name ?? '';
        const matchesSet = card.dataset.set === selectedSet;
        const matchesFaction = !selectedFaction || card.dataset.faction === selectedFaction;
        const matchesClass = !selectedClass || card.dataset.class === selectedClass;
        const matchesSearch = roleName.includes(searchTerm);
        const isVisible = matchesSet && matchesFaction && matchesClass && matchesSearch;

        card.style.display = isVisible ? 'block' : 'none';
        if (isVisible) visibleCount++;
      });

      noResults.classList.toggle('hidden', visibleCount > 0);
    }

    // Initialize filter on load to ensure "Standard" is shown immediately
    filterRoles();

    document.getElementById('setFilter')?.addEventListener('change', filterRoles);
    document.getElementById('factionFilter')?.addEventListener('change', filterRoles);
    document.getElementById('classFilter')?.addEventListener('change', filterRoles);
    document.getElementById('searchInput')?.addEventListener('input', filterRoles);
  });
</script>